    {
      "name": "P3 WebSocket and Real-Time Communication",
      "description": "Postman dapat dipakai untuk HTTP event API dan trigger real WebSocket packet. WebSocket asli menggunakan HTTP Upgrade ke ws://localhost:8088/ws/echo?channel=dashboard. Wireshark: tcp.port == 8088, http.request.uri contains \"/ws/echo\", lalu websocket setelah 101 Switching Protocols.",
      "item": [
        {
          "name": "GET WebSocket Capture Guide",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/websocket/real-status"
          }
        },
        {
          "name": "POST Real WebSocket Capture Trigger",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"channel\": \"dashboard\",\n  \"payload\": {\n    \"event\": \"dashboard_refresh\",\n    \"value\": 1,\n    \"source\": \"postman-websocket-capture\"\n  }\n}"},
            "url": "{{base_url}}/api/websocket/real-send"
          }
        },
        {
          "name": "POST Realtime Dashboard Event",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"channel\": \"dashboard\",\n  \"event\": \"dashboard_refresh\",\n  \"transport\": \"http-post-event\",\n  \"payload\": {\n    \"dashboard\": \"sales-ops\",\n    \"changedMetric\": \"orders_per_minute\",\n    \"value\": 12\n  }\n}"},
            "url": "{{base_url}}/api/realtime/events"
          }
        },
        {
          "name": "POST Realtime Alert Event",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"channel\": \"alerts\",\n  \"event\": \"sensor_alert\",\n  \"transport\": \"http-post-event\",\n  \"payload\": {\n    \"deviceId\": \"sensor-02\",\n    \"temperature\": 39.4,\n    \"severity\": \"warning\"\n  }\n}"},
            "url": "{{base_url}}/api/realtime/events"
          }
        },
        {
          "name": "GET Dashboard Events",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/realtime/events?channel=dashboard"
          }
        },
        {
          "name": "GET Alert Events",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/realtime/events?channel=alerts"
          }
        }
      ]
    },
    {
      "name": "P4 MQTT and IoT Telemetry Simulator",
      "description": "Simulator konsep publish/subscribe plus trigger real MQTT 3.1.1 packet capture. server.py menjalankan embedded MQTT broker pada 127.0.0.1:1883. Untuk session yang tidak disconnect, gunakan POST /api/mqtt/session/start lalu inspect PINGREQ/PINGRESP di Wireshark.",
      "item": [
        {
          "name": "POST Publish Temperature Telemetry",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"clientId\": \"student-client-01\",\n  \"topic\": \"class/commproto/sensor-01/temperature\",\n  \"qos\": 1,\n  \"retained\": true,\n  \"payload\": {\n    \"deviceId\": \"sensor-01\",\n    \"temperature\": 27.5,\n    \"humidity\": 61\n  }\n}"},
            "url": "{{base_url}}/api/mqtt/publish"
          }
        },
        {
          "name": "POST Publish Humidity Telemetry",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"clientId\": \"student-client-02\",\n  \"topic\": \"class/commproto/sensor-02/humidity\",\n  \"qos\": 0,\n  \"retained\": false,\n  \"payload\": {\n    \"deviceId\": \"sensor-02\",\n    \"humidity\": 72,\n    \"battery\": 88\n  }\n}"},
            "url": "{{base_url}}/api/mqtt/publish"
          }
        },
        {
          "name": "GET Real MQTT Broker Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/mqtt/real-status"
          }
        },
        {
          "name": "POST Real MQTT Packet Publish",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"clientId\": \"student-client-01\",\n  \"topic\": \"class/commproto/sensor-01/temperature\",\n  \"filter\": \"class/commproto/+/temperature\",\n  \"qos\": 1,\n  \"retained\": true,\n  \"payload\": {\n    \"deviceId\": \"sensor-01\",\n    \"temperature\": 27.5,\n    \"humidity\": 61\n  }\n}"},
            "url": "{{base_url}}/api/mqtt/real-publish"
          }
        },
        {
          "name": "POST Start Persistent MQTT Session",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"clientId\": \"student-client-01\",\n  \"topic\": \"class/commproto/sensor-01/temperature\",\n  \"filter\": \"class/commproto/+/temperature\",\n  \"qos\": 1,\n  \"retained\": true,\n  \"keepaliveIntervalSeconds\": 15,\n  \"payload\": {\n    \"deviceId\": \"sensor-01\",\n    \"temperature\": 27.5,\n    \"humidity\": 61\n  }\n}"},
            "url": "{{base_url}}/api/mqtt/session/start"
          }
        },
        {
          "name": "GET Persistent MQTT Session Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/mqtt/session/status"
          }
        },
        {
          "name": "POST Stop Persistent MQTT Session",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"clientId\": \"student-client-01\"\n}"},
            "url": "{{base_url}}/api/mqtt/session/stop"
          }
        },
        {
          "name": "GET Exact Topic Messages",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/mqtt/messages?topic=class/commproto/sensor-01/temperature"
          }
        },
        {
          "name": "GET Subscribe Filter class/commproto/+/temperature",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/mqtt/messages?filter=class/commproto/+/temperature"
          }
        },
        {
          "name": "GET Topics and Retained Messages",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/mqtt/topics"
          }
        },
        {
          "name": "Clear MQTT Simulator Messages",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/mqtt/clear"
          }
        }
      ]
    },
    {
      "name": "P5 gRPC and Protocol Buffers Concept",
      "description": "Folder ini memakai endpoint concept mock berbasis HTTP/1.1 untuk membaca service contract, plus endpoint trigger /api/grpc/http2-call yang memanggil real gRPC HTTP/2 server terintegrasi di server.py pada port 50051. Tidak perlu edit .proto untuk demo standar; pilih method dan kirim sample payload. Capture Wireshark: tcp.port == 50051 lalu Decode As HTTP2 jika perlu.",
