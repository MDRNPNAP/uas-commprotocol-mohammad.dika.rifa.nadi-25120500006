{
  "info": {
    "name": "Communication Protocols Demo App - Advanced RPS Aligned",
    "description": "Postman collection untuk demo Communication Protocols berbasis RPS. REST CRUD tetap ditempatkan sebagai P2 recap. P3 ke atas dibuat lebih interaktif: WebSocket event API, MQTT topic/filter/payload, gRPC-style call, encoding converter, troubleshooting, API documentation runner, reliability, microservices, observability, n8n automation, dan UAS project evidence.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8088"
    }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('response code is expected for lab scenario', function () {",
          "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 204, 400, 401, 404, 429, 500]);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Wireshark Capture Matrix",
      "description": "Gunakan folder ini untuk melihat port, trigger endpoint, expected packet, dan filter Wireshark per pertemuan.",
