      "item": [
        {"name": "GET TLS Capture Guide", "request": {"method": "GET", "url": "{{base_url}}/api/tls/status"}},
        {"name": "POST TLS Self-Test Capture Trigger", "request": {"method": "POST", "url": "{{base_url}}/api/tls/self-test"}},
        {"name": "Health 200", "request": {"method": "GET", "url": "{{base_url}}/api/health"}},
        {"name": "Status 400", "request": {"method": "GET", "url": "{{base_url}}/api/troubleshooting/status/400"}},
        {"name": "Status 404", "request": {"method": "GET", "url": "{{base_url}}/api/troubleshooting/status/404"}},
